  <div class="container">
    <a href="/" class="logo">
      <i class="fas fa-book-open"></i>
      MangaHay
    </a>
    
    <div class="navbar-search">
      <input type="text" id="navSearchInput" placeholder="Tìm kiếm truyện..." onkeypress="if(event.key==='Enter') searchManga()">
      <button onclick="searchManga()" class="search-btn">
        <i class="fas fa-search"></i>
      </button>
    </div>
    
    <ul class="nav-links">
