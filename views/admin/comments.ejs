<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/admin.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
  </head>
  <body>
    <%- include('../partials/navbar') %>

    <main>
      <div class="container">
        <h1 class="page-title">Quản Lý Bình Luận</h1>

        <!-- Admin Navigation -->
        <div class="admin-nav">
          <a href="/admin" class="admin-nav-link">Bảng Điều Khiển</a>
          <a href="/admin/manga" class="admin-nav-link">Quản Lý Truyện</a>
          <a href="/admin/users" class="admin-nav-link">Quản Lý Người Dùng</a>
          <a href="/admin/comments" class="admin-nav-link active"
            >Quản Lý Bình Luận</a
          >
          <a href="/admin/sliders" class="admin-nav-link">Quản Lý Slider</a>
        </div>

        <div class="section">
          <p class="section-info">
            <i class="fas fa-info-circle"></i>
            Hiển thị 50 bình luận gần đây nhất trên toàn hệ thống
          </p>
        </div>

        <!-- Comments Table -->
        <div id="commentsTable" class="admin-table-container">
          <div class="loading">Đang tải bình luận...</div>
        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="/js/main.js"></script>
    <script src="/js/admin/comments.js"></script>
  </body>
</html>
